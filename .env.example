# Scaleway account
export SCW_REGION=fr-par
export SCW_ACCESS_KEY=<your-access-key>
export SCW_SECRET_KEY=<your-secret-key>
export SCW_DEFAULT_ORGANIZATION_ID=<your-org-id>
export SCW_DEFAULT_PROJECT_ID=<your-project-id>

# Application credentials
export GRAFANA_ADMIN_PASSWORD=<your-grafana-password>
export MATOMO_ADMIN_PASSWORD=<your-matomo-password>
export MATOMO_TOKEN_AUTH=<your-matomo-auth-token>
export WISDOM_API_AUTH_TOKEN=<your-api-auth-token>

# Jeanne agent
export MISTRAL_API_KEY=<your-mistral-api-key>
export JEANNE_MATRIX_ACCESS_TOKEN=<jeanne-matrix-access-token>
export GITHUB_APP_ID=<github-app-id>
export GITHUB_APP_INSTALLATION_ID=<github-app-installation-id>
export GITHUB_APP_PRIVATE_KEY="$(cat /path/to/jeanne-sovereign-agent.private-key.pem)"
export JEANNE_SCW_ACCESS_KEY=<jeanne-scaleway-access-key>
export JEANNE_SCW_SECRET_KEY=<jeanne-scaleway-secret-key>

# IAM scoped API keys (created via: scw iam api-key create application-id=<id>)
export DNS_MANAGER_ACCESS_KEY=<dns-manager-access-key>
export DNS_MANAGER_SECRET_KEY=<dns-manager-secret-key>
export CNPG_BACKUP_ACCESS_KEY=<cnpg-backup-access-key>
export CNPG_BACKUP_SECRET_KEY=<cnpg-backup-secret-key>
export ESO_READER_ACCESS_KEY=<eso-reader-access-key>
export ESO_READER_SECRET_KEY=<eso-reader-secret-key>

export KUBECONFIG="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/infrastructure/dev/.kubeconfig"
