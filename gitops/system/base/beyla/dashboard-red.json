{
    "annotations": {
        "list": []
    },
    "description": "HTTP RED metrics (Rate, Errors, Duration) from Beyla eBPF instrumentation",
    "editable": true,
    "graphTooltip": 1,
    "panels": [
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "id": 100,
            "title": "Request Rate",
            "type": "row"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "fillOpacity": 10,
                        "showPoints": "never"
                    },
                    "unit": "reqps"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 1
            },
            "id": 1,
            "options": {
                "tooltip": {
                    "mode": "multi"
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum by (http_route) (rate(http_server_request_duration_seconds_count{service_name=~\"$service\", k8s_namespace_name=~\"$namespace\", http_route!=\"\"}[$__rate_interval]))",
                    "legendFormat": "{{ http_route }}"
                }
            ],
            "title": "Request Rate by Endpoint",
            "type": "timeseries"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "fillOpacity": 10,
                        "showPoints": "never"
                    },
                    "unit": "reqps"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 1
            },
            "id": 2,
            "options": {
                "tooltip": {
                    "mode": "multi"
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum by (http_response_status_code) (rate(http_server_request_duration_seconds_count{service_name=~\"$service\", k8s_namespace_name=~\"$namespace\", http_route!=\"\"}[$__rate_interval]))",
                    "legendFormat": "{{ http_response_status_code }}"
                }
            ],
            "title": "Request Rate by Status Code",
            "type": "timeseries"
        },
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 9
            },
            "id": 101,
            "title": "Latency",
            "type": "row"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "fillOpacity": 10,
                        "showPoints": "never"
                    },
                    "unit": "s"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 10
            },
            "id": 5,
            "options": {
                "tooltip": {
                    "mode": "multi"
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_seconds_bucket{service_name=~\"$service\", k8s_namespace_name=~\"$namespace\", http_route!=\"\"}[$__rate_interval])))",
                    "legendFormat": "{{ http_route }}"
                }
            ],
            "title": "p95 Latency by Endpoint",
            "type": "timeseries"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "s"
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 10
            },
            "id": 8,
            "options": {
                "footer": {
                    "enablePagination": false
                },
                "sortBy": [
                    {
                        "desc": true,
                        "displayName": "p95"
                    }
                ]
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.50, sum by (le, http_route) (rate(http_server_request_duration_seconds_bucket{service_name=~\"$service\", k8s_namespace_name=~\"$namespace\", http_route!=\"\"}[$__rate_interval])))",
                    "legendFormat": "{{ http_route }}",
                    "instant": true,
                    "format": "table",
                    "refId": "p50"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.95, sum by (le, http_route) (rate(http_server_request_duration_seconds_bucket{service_name=~\"$service\", k8s_namespace_name=~\"$namespace\", http_route!=\"\"}[$__rate_interval])))",
                    "legendFormat": "{{ http_route }}",
                    "instant": true,
                    "format": "table",
                    "refId": "p95"
                },
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "histogram_quantile(0.99, sum by (le, http_route) (rate(http_server_request_duration_seconds_bucket{service_name=~\"$service\", k8s_namespace_name=~\"$namespace\", http_route!=\"\"}[$__rate_interval])))",
                    "legendFormat": "{{ http_route }}",
                    "instant": true,
                    "format": "table",
                    "refId": "p99"
                }
            ],
            "title": "Latency Summary (p50 / p95 / p99)",
            "type": "table",
            "transformations": [
                {
                    "id": "merge"
                },
                {
                    "id": "organize",
                    "options": {
                        "excludeByName": {
                            "Time": true
                        },
                        "renameByName": {
                            "http_route": "Endpoint",
                            "Value #p50": "p50",
                            "Value #p95": "p95",
                            "Value #p99": "p99"
                        }
                    }
                }
            ]
        },
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 18
            },
            "id": 103,
            "title": "Throughput",
            "type": "row"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "fillOpacity": 10,
                        "showPoints": "never",
                        "stacking": {
                            "mode": "normal"
                        }
                    },
                    "unit": "Bps"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 19
            },
            "id": 6,
            "options": {
                "tooltip": {
                    "mode": "multi"
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum by (http_route) (rate(http_server_request_body_size_bytes_sum{service_name=~\"$service\", k8s_namespace_name=~\"$namespace\", http_route!=\"\"}[$__rate_interval]))",
                    "legendFormat": "{{ http_route }}"
                }
            ],
            "title": "Request Body Throughput",
            "type": "timeseries"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "fillOpacity": 10,
                        "showPoints": "never",
                        "stacking": {
                            "mode": "normal"
                        }
                    },
                    "unit": "Bps"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 19
            },
            "id": 7,
            "options": {
                "tooltip": {
                    "mode": "multi"
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum by (http_route) (rate(http_server_response_body_size_bytes_sum{service_name=~\"$service\", k8s_namespace_name=~\"$namespace\", http_route!=\"\"}[$__rate_interval]))",
                    "legendFormat": "{{ http_route }}"
                }
            ],
            "title": "Response Body Throughput",
            "type": "timeseries"
        }
    ],
    "schemaVersion": 39,
    "tags": [
        "beyla",
        "ebpf",
        "red"
    ],
